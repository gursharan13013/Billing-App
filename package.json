  "version": "2.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "build:android": "node scripts/heal-gradle.js && vite build && npx cap sync android",
    "build:apk": "npm run build:android && cd android && ./gradlew assembleDebug",
    "build:apk:release": "npm run build:android && cd android && ./gradlew assembleRelease",
    "build:ios": "vite build && npx cap sync ios",
    "lint": "tsc --noEmit"
  },
