    "@google/genai": "^1.49.0",
    "@supabase/supabase-js": "2.39.3",
    "dexie": "^4.0.8",
    "dexie-export-import": "^4.4.0",
    "dexie-react-hooks": "^4.4.0",
    "firebase": "^12.12.0",
    "html5-qrcode": "2.3.8",
    "leaflet": "1.9.4",
    "lucide-react": "^0.562.0",
    "lz-string": "^1.5.0",
